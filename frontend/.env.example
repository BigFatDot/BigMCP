# BigMCP Frontend - Environment Configuration
# Copy this file to .env.development or .env.production

# ==========================================
# Deployment Mode
# ==========================================
# Options: cloud, self_hosted
# - cloud: BigMCP demo platform at app.bigmcp.cloud
# - self_hosted: Your own instance (default, all features enabled)
VITE_DEPLOYMENT_MODE=self_hosted

# ==========================================
# API Configuration
# ==========================================
# Base URL for all API calls (auth, marketplace, servers, etc.)
# The frontend ALWAYS calls the local backend - it handles routing
# Default: /api/v1 (proxied through Nginx or Vite dev server)
VITE_API_BASE_URL=/api/v1

# ==========================================
# Architecture Notes
# ==========================================
# Self-Hosted (default):
#   - Frontend: served from your server
#   - API: /api/v1 -> Nginx -> backend:8001
#   - All features enabled, unlimited users
#   - Marketplace: backend proxies to api.bigmcp.cloud/marketplace
#
# Cloud (app.bigmcp.cloud):
#   - Free demo/trial platform
#   - API: /api/v1 -> Nginx -> backend:8001
#   - Marketplace: backend queries internal DB + Glama/Smithery
