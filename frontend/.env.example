# BigMCP Frontend - Environment Configuration
# Copy this file to .env.development or .env.production

# ==========================================
# Deployment Mode
# ==========================================
# Options: cloud, self_hosted_community, self_hosted_enterprise
# - cloud: SaaS at app.bigmcp.cloud (requires subscription)
# - self_hosted_community: Free, single user, MIT license
# - self_hosted_enterprise: Paid license, multi-user, RBAC
VITE_DEPLOYMENT_MODE=self_hosted_community

# ==========================================
# API Configuration
# ==========================================
# Base URL for all API calls (auth, marketplace, servers, etc.)
# The frontend ALWAYS calls the local backend - it handles routing
# Default: /api/v1 (proxied through Nginx or Vite dev server)
VITE_API_BASE_URL=/api/v1

# ==========================================
# Architecture Notes
# ==========================================
# Cloud SaaS (app.bigmcp.cloud):
#   - Frontend: served from CDN
#   - API: /api/v1 -> Nginx -> backend:8001
#   - Marketplace: backend queries internal DB + Glama/Smithery
#
# Self-Hosted (Community/Enterprise):
#   - Frontend: served from your server
#   - API: /api/v1 -> Nginx -> backend:8001
#   - Marketplace: backend proxies to api.bigmcp.cloud/marketplace
#                  (requires MARKETPLACE_API_KEY in backend .env)
