# ===========================================
# BigMCP Production Environment Template
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ----- DATABASE -----
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=bigmcp
POSTGRES_USER=bigmcp

# ----- SECURITY -----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_generate_with_secrets_token_urlsafe_32
JWT_SECRET_KEY=change_this_generate_with_secrets_token_urlsafe_32

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_this_generate_fernet_key

# ----- LLM PROVIDER -----
# Mistral AI (recommended for production)
MISTRAL_API_KEY=your_mistral_api_key_here

# Or use any OpenAI-compatible API:
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4

# ----- SSL CERTIFICATE -----
# Email for Let's Encrypt notifications
CERTBOT_EMAIL=admin@yourdomain.com

# ----- DOMAIN -----
DOMAIN=yourdomain.com

# ----- OPTIONAL: MONITORING -----
# ENABLE_METRICS=true
# METRICS_PORT=9090

# ----- OPTIONAL: RATE LIMITING -----
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60
