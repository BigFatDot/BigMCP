# BigMCP Gateway - .gitignore
# Professional Repository Configuration

# ===========================================
# ENVIRONMENT & SECRETS
# ===========================================
# Never commit actual secrets
.env
.env.local
.env.development
.env.staging
# Keep example files
!.env.example
!.env.production.example

# Edition system secrets (private keys, tokens)
mcp-registry/secrets/
secrets/

# Internal scripts (deployment, license generation, ops)
scripts/
mcp-registry/scripts/

# ===========================================
# DEVELOPMENT ARCHIVES
# ===========================================
_legacy/
_dev_archive/

# ===========================================
# PYTHON
# ===========================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/
.direnv/
.envrc

# IDEs
.vscode/
.idea/
.DS_Store

# MCP Registry runtime
mcp-registry/embeddings_cache/
mcp-registry/data/
mcp-registry/logs/
mcp-registry/.cache/

# MCP Registry runtime config (contains user data, tokens, caches)
mcp-registry/conf/mcp_servers.json
mcp-registry/conf/server_visibility.json
mcp-registry/conf/curated_servers_cache.json
mcp-registry/conf/marketplace_registry.json
mcp-registry/conf/source_config.json
mcp-registry/conf/bigmcp_source.json

# MCP Orchestrator runtime
albert-mcp-orchestrator/logs/
albert-mcp-orchestrator/metrics/
albert-mcp-orchestrator/compositions/*.json
albert-mcp-orchestrator/temp/

