!docker-compose.example.yml
nginx/
certbot/

# ===========================================
# SAAS-ONLY (VPS /opt/bigmcp — never in public repo)
# ===========================================
# All SaaS production scripts live in saas/ on the VPS.
# Self-hosted users don't need them; secrets would be exposed if committed.
#
# saas/
# ├── generate-i18n-landing.py   # 22-language landing pages (SEO, full HTML)
# ├── generate-changelog.py      # /changelog static page from CHANGELOG.md
# ├── generate-integrations.py   # 184 /integrations/{slug} pages (+ Mistral LLM)
# ├── post-deploy.sh             # Run after: docker compose up -d --build frontend
# │                              #   → generates all static content + nginx reload
# ├── seo-gen.log                # Cron output log
# ├── i18n-html/                 # Generated: index.{lang}.html (22 files × 31 KB)
# └── static/
#     ├── changelog/index.html   # Generated: /changelog page
#     ├── integrations/          # Generated: 184 server pages + index
#     │   ├── index.html
#     │   └── {slug}/index.html
#     └── sitemap-integrations.xml
#
# Cron (root crontab on VPS):
#   @reboot  sleep 60 && bash /opt/bigmcp/saas/post-deploy.sh >> saas/seo-gen.log 2>&1
#   0 3 * * * bash /opt/bigmcp/saas/post-deploy.sh >> saas/seo-gen.log 2>&1
#
# docker-compose.override.yml (also gitignored) mounts:
#   ./saas/i18n-html  → /var/www/i18n   (nginx)
#   ./saas/static     → /var/www/static  (nginx)
saas/
marketplace_test.json

# Third-party registry configs (VPS-only, not for public repo)
smithery.yaml

# SaaS-specific sitemaps (bigmcp.cloud URLs, generated on VPS)
frontend/public/sitemap-main.xml

# Build artifacts
*.tar.gz

# ===========================================
# TWA BUILD
# ===========================================
twa/output/
twa/build/
twa/.env
twa/keystore/
