# ==========================================
# BigMCP Gateway - Environment Configuration
# ==========================================

# ----------------
# LLM API Configuration (for AI orchestration)
# ----------------
# Any OpenAI-compatible API works:
LLM_API_URL=https://api.mistral.ai/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=mistral-small-latest

# Alternative providers:
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# ----------------
# MCP Registry Configuration
# ----------------
MCP_REGISTRY_PORT=8001
MCP_SERVERS_CONFIG_PATH=./conf/mcp_servers.json

# ----------------
# Embedding API Configuration (for semantic search)
# ----------------
# By default, uses the same API as LLM (Mistral)
# Override with EMBEDDING_API_URL/EMBEDDING_API_KEY for a different provider
# EMBEDDING_API_URL=https://api.mistral.ai/v1
# EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_MODEL=mistral-embed

# Alternative models:
# For OpenAI: text-embedding-3-small

VECTOR_STORE_PATH=./data/vector_store

# ----------------
# Logging
# ----------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------
# Performance Tuning
# ----------------
MAX_WORKERS=4
CACHE_TTL=3600
MAX_CONCURRENT_TOOL_EXECUTIONS=10
TOOL_EXECUTION_TIMEOUT_SECONDS=60

# ----------------
# SSE Configuration
# ----------------
SSE_KEEPALIVE_INTERVAL_SECONDS=30
SSE_RETRY_INTERVAL_MS=1000

# ----------------
# Optional: External MCP Servers
# ----------------
# Grist MCP Server
# GRIST_API_KEY=your_grist_api_key_here
# GRIST_API_URL=https://your-grist-instance.com

# GitHub MCP Server
# GITHUB_TOKEN=your_github_token_here

# ----------------
# Edition System
# ----------------
# BigMCP edition: community or enterprise
# Auto-detected based on LICENSE_KEY presence
# EDITION=community

# Enterprise Edition: License key (JWT signed with ES256)
# Obtain from https://bigmcp.cloud/enterprise
# LICENSE_KEY=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9...


# ----------------
# Authentication & Security (REQUIRED)
# ----------------
# Secret key for signing JWT tokens (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# JWT token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for storing credentials (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=change-this-to-another-random-key-min-32-chars

# API key prefix
API_KEY_PREFIX=bigmcp_sk_

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ----------------
# Database (REQUIRED)
# ----------------
# PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://bigmcp:bigmcp@postgres:5432/bigmcp

# ----------------
# Application
# ----------------
# Debug mode (set to true for development)
DEBUG=false

# Auto-reload on code changes (set to true for development)
RELOAD=false

# ----------------
# CORS
# ----------------
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# ----------------
# Marketplace API (Self-Hosted)
# ----------------
# All self-hosted deployments connect to the centralized Marketplace API
# Register at bigmcp.cloud to get your API key
MARKETPLACE_API_URL=https://api.bigmcp.cloud/marketplace
MARKETPLACE_API_KEY=your_marketplace_api_key_here

# Cache settings for marketplace data
MARKETPLACE_CACHE_TTL_HOURS=24

# ----------------
# Email Service (SMTP)
# ----------------
# SMTP configuration for password reset and team invitations
# SMTP_PORT=465
# SMTP_USER=noreply@bigmcp.cloud
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM_EMAIL=noreply@bigmcp.cloud
# SMTP_FROM_NAME=BigMCP
# SMTP_USE_TLS=false
# SMTP_USE_SSL=true

# Token expiration settings
# PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24
# INVITATION_EXPIRE_DAYS=7

# ----------------
# Optional: Monitoring
# ----------------
# ENABLE_METRICS=true
# METRICS_PORT=9090

