# ==============================================================================
# BigMCP — Environment Configuration
# ==============================================================================
# Copy to `.env` and fill in the REQUIRED values. Everything else has safe
# defaults baked into docker-compose.yml.
#
# Generate the two required secrets with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"           # SECRET_KEY
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # ENCRYPTION_KEY
#
# ⚠️  Treat ENCRYPTION_KEY as you would a database password — if you lose it,
#     every credential stored by every user becomes permanently unreadable.
#     Back it up out-of-band (e.g. a vault) before going to production.
# ==============================================================================


# ------------------------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------------------------

# JWT signing key. Min 32 chars. NEVER commit a real value.
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# Symmetric Fernet key for at-rest encryption of user credentials.
# Must be a 44-char base64-encoded 32-byte key.
ENCRYPTION_KEY=change-this-to-a-fernet-key-44-base64-chars

# PostgreSQL connection. Default values match docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://bigmcp:bigmcp_dev_password@postgres:5432/bigmcp


# ------------------------------------------------------------------------------
# EDITION — community (default) | enterprise | cloud_saas
# ------------------------------------------------------------------------------
# EDITION=community
# LICENSE_KEY=                  # only for EDITION=enterprise — signed JWT
# SAAS_TOKEN=                   # only for EDITION=cloud_saas — internal BigFatDot SaaS


# ------------------------------------------------------------------------------
# INSTANCE BRANDING (white-label your self-hosted deploy)
# ------------------------------------------------------------------------------
# All optional. Values set here become the env-level fallback for the
# instance_settings table; the admin UI at /app/admin/instance-branding
# always wins. Restart picks up env changes.
#
# INSTANCE_NAME=Acme MCP
# INSTANCE_TAGLINE=Internal MCP gateway for the Acme team
# INSTANCE_LOGO_URL=https://acme.example.com/logo.svg
# INSTANCE_FAVICON_URL=https://acme.example.com/favicon.ico
# INSTANCE_PRIMARY_COLOR=#1e6fab
# INSTANCE_SUPPORT_EMAIL=support@acme.example.com
# INSTANCE_URL=https://mcp.acme.example.com
# INSTANCE_LEGAL_ENTITY=Acme Inc.
# INSTANCE_WELCOME_MESSAGE=Welcome to our internal MCP gateway. Sign in with your work account.


# ------------------------------------------------------------------------------
# SECURITY POSTURE
# ------------------------------------------------------------------------------
# Scope enforcement for API keys. Flip to "enforce" once your keys are
# correctly scoped (see audit logs for shadow-mode denials before flipping).
#   enforce  → deny calls missing the required scope (recommended for prod)
#   log_only → audit-only (emergency rollback kill-switch)
#   <unset>  → fall back to each callsite's own default (currently log_only)
SCOPE_ENFORCE_MODE=enforce

# JWT lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API key prefix (changing this invalidates docs alignment — leave alone for v1)
API_KEY_PREFIX=bigmcp_sk_

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Rate limiting (stricter limits apply to /auth and /api-keys regardless)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60


# ------------------------------------------------------------------------------
# DATABASE POOL (size for your workload)
# ------------------------------------------------------------------------------
# Defaults match the prod deploy. Raise if you see TooManyConnections in logs.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20


# ------------------------------------------------------------------------------
# LLM PROVIDER — bring your own (any OpenAI-compatible /chat/completions)
# ------------------------------------------------------------------------------
# Tested providers: Mistral (default), OpenAI, Ollama, vLLM.
# Anthropic is NOT supported here — its API is not OpenAI-compatible.
LLM_API_URL=https://api.mistral.ai/v1
LLM_API_KEY=
LLM_MODEL=mistral-small-latest

# Provider examples:
# LLM_API_URL=https://api.openai.com/v1   ; LLM_MODEL=gpt-4o-mini
# LLM_API_URL=http://ollama:11434/v1      ; LLM_MODEL=llama3.1
# LLM_API_URL=http://vllm:8000/v1         ; LLM_MODEL=meta-llama/Llama-3-8B-Instruct


# ------------------------------------------------------------------------------
# EMBEDDINGS (semantic search across MCP tools)
# ------------------------------------------------------------------------------
# Defaults reuse the LLM provider. Override only if you need a separate one.
# EMBEDDING_API_URL=https://api.mistral.ai/v1
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=mistral-embed
# Output dimension of your embedding model. Mistral-embed=1024, OpenAI
# text-embedding-3-small=1536, nomic-embed-text=768. Set this to match your
# model; smaller dimensions are zero-padded.
EMBEDDING_DIMENSION=1536
VECTOR_STORE_PATH=./data/vector_store


# ------------------------------------------------------------------------------
# RERANKING (optional — Mistral-style /rerank endpoint)
# ------------------------------------------------------------------------------
# Off by default. Only Mistral exposes /rerank in an OpenAI-compatible way;
# Ollama/OpenAI/vLLM don't, so leaving this off keeps you portable.
# When enabled, falls back to LLM_API_URL if RERANK_API_URL is unset.
RERANK_ENABLED=false
# RERANK_API_URL=https://api.mistral.ai/v1
# RERANK_MODEL=rerank-small


# ------------------------------------------------------------------------------
# AIR-GAP DEPLOYMENT — fully self-hosted, no outbound traffic except your LLM
# ------------------------------------------------------------------------------
# When AIRGAP_MODE=true, BigMCP makes ZERO outbound HTTP calls besides the
# configured LLM provider:
#   - Marketplace sync (npm, GitHub) is disabled
#   - Icon CDNs (SimpleIcons, LobeHub, ui-avatars) are replaced by inline SVG
#   - LemonSqueezy is never contacted
# Use with a local LLM (Ollama, vLLM) to run completely offline.
# Verify with: curl http://localhost:8001/edition/status → `airgap: true`
AIRGAP_MODE=false


# ------------------------------------------------------------------------------
# EMAIL (SMTP) — required for invitations + password reset to actually deliver
# ------------------------------------------------------------------------------
# Without SMTP, invitations and password-reset emails are still GENERATED (and
# the links are visible to instance admins in /api/v1/admin/audit-logs), but
# nothing leaves the box. Configure SMTP before opening up to real users.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=BigMCP            # falls back to INSTANCE_NAME in email body
# SMTP_USE_SSL=true
# SMTP_USE_TLS=false


# ------------------------------------------------------------------------------
# REGISTRY + RUNTIME
# ------------------------------------------------------------------------------
MCP_REGISTRY_PORT=8001
MCP_SERVERS_CONFIG_PATH=./conf/mcp_servers.json

LOG_LEVEL=INFO
LOG_FORMAT=json

MAX_WORKERS=4
CACHE_TTL=3600
MAX_CONCURRENT_TOOL_EXECUTIONS=10
TOOL_EXECUTION_TIMEOUT_SECONDS=60

SSE_KEEPALIVE_INTERVAL_SECONDS=30
SSE_RETRY_INTERVAL_MS=1000

# Per-user / global MCP server pool caps
POOL_MAX_SERVERS_PER_USER=10
POOL_MAX_TOTAL_SERVERS=100
POOL_CLEANUP_TIMEOUT_MINUTES=5


# ------------------------------------------------------------------------------
# APP MODE
# ------------------------------------------------------------------------------
# DEBUG=true / RELOAD=true are for local dev ONLY — never enable in production.
DEBUG=false
RELOAD=false


# ------------------------------------------------------------------------------
# CORS — comma-separated origins allowed to call the API directly
# ------------------------------------------------------------------------------
# Default covers a local dev frontend + nginx-served app. In production set
# this to your real domain(s) to avoid drive-by browser calls.
CORS_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1:8080


# ------------------------------------------------------------------------------
# BILLING / SAAS-ONLY (ignore for self-host)
# ------------------------------------------------------------------------------
# Only loaded when EDITION=cloud_saas. Leave empty otherwise.
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_INDIVIDUAL_VARIANT_ID=
# LEMONSQUEEZY_TEAM_VARIANT_ID=
# LEMONSQUEEZY_ENTERPRISE_VARIANT_ID=
# PUBLIC_SECTOR_COUPON_CODE=
# PLATFORM_ADMIN_TOKEN=
